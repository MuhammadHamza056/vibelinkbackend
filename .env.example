# --- Server ---
PORT=3000
NODE_ENV=development

# --- MongoDB ---
# Atlas SRV URI. If your password has special chars (@ : / ? # etc.) URL-encode them.
# Example: '@' -> '%40'
MONGODB_URI=mongodb+srv://<user>:<url-encoded-password>@<cluster>.mongodb.net/vibelink?retryWrites=true&w=majority

# --- JWT ---
JWT_SECRET=use_a_long_random_secret
JWT_EXPIRES_IN=30d

# --- ngrok (optional) ---
NGROK_AUTHTOKEN=
